# Variables de entorno del backend en producción.
# En Cloud Run se inyectan vía GitHub Secrets (ver .github/workflows/deploy-backend.yml).
# Este archivo es plantilla para correr local o documentar lo requerido.

# ── Runtime (las únicas que necesita Cloud Run) ─────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
ALLOWED_ORIGINS=https://elige-tuplan.cl,https://www.elige-tuplan.cl

# ── ETL local (NO setear en Cloud Run) ──────────────────────────────────
# Solo se usan al correr scripts/sync_sis.py o scripts/sync_tu7.py desde tu PC.
# SUPABASE_SERVICE_ROLE_KEY bypassea RLS — nunca exponerla al frontend ni a Cloud Run.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SIS_PERIOD=202602
